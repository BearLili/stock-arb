# 复制为 .env 并按需修改。M0/M1 监控进程无需交易密钥（只读行情）。
NODE_ENV=production
# 服务器强制 UTC（s4s5 已在 duckdb 内 SET TimeZone='UTC'，此处再兜底进程时区）
TZ=UTC
LOG_LEVEL=info
# 配置文件路径
CONFIG=monitor_config.json
# 健康报表间隔（秒）
REPORT_EVERY=60
# 告警 webhook（可选，留空则不投递）——填你自己的端点
# ALERT_WEBHOOK=https://your-endpoint.example/alert
# 关闭落盘（仅冒烟用；长跑请勿设）——注意两入口变量名不同：
#   collector 用 NO_RECORD=1；engine 用 RECORD=0
# NO_RECORD=1
# RECORD=0
