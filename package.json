{
  "name": "stock-arb",
  "version": "0.1.0",
  "description": "跨交易所股票代币/永续套利监控系统 (M0 collector + M1 净edge引擎)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "collector": "tsx src/collector.ts",
    "engine": "tsx src/engineMain.ts",
    "validate:m1": "tsx scripts/validateM1.ts",
    "report:s4s5": "tsx scripts/s4s5Report.ts",
    "query": "tsx scripts/query.ts",
    "health": "tsx scripts/healthcheck.ts",
    "runlog": "tsx scripts/runlog.ts",
    "paper": "tsx scripts/paperRun.ts",
    "test:paper": "tsx scripts/testPaper.ts",
    "test:exec": "tsx scripts/testExec.ts",
    "sweep": "tsx scripts/sweep.ts",
    "measure:rtt": "tsx scripts/measureRtt.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "duckdb": "^1.1.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "undici": "^7.3.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3"
  }
}
